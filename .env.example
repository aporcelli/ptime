# ─────────────────────────────────────────────────────────────────────────────
# Ptime — Variables de Entorno (plantilla)
# Copiar a .env.local y completar con valores reales.
# NUNCA commitear .env.local con credenciales reales.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
# Tipo: OAuth 2.0 Client ID (Web Application)
# Redirect URI permitida: https://tu-dominio.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generar secret: openssl rand -base64 32
NEXTAUTH_SECRET=
# URL base de la app (sin slash final)
NEXTAUTH_URL=https://tu-dominio.vercel.app

# ── Configuración ─────────────────────────────────────────────────────────────
# Email del primer usuario con rol ADMIN
ADMIN_EMAIL=

# ── Opcional: URL pública (si se necesita en cliente) ─────────────────────────
# NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# ── Log Level (development | production) ─────────────────────────────────────
# LOG_LEVEL=info
