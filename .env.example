# ─────────────────────────────────────────────────────────────────────────────
# Ptime — Variables de Entorno
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA commitear .env.local al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Sheets API ─────────────────────────────────────────────────────────
# Crear Service Account en: https://console.cloud.google.com/iam-admin/serviceaccounts
# Habilitar Google Sheets API en el proyecto de GCP
# Compartir el Spreadsheet con el email de la Service Account (rol Editor)
GOOGLE_SERVICE_ACCOUNT_EMAIL="ptime-service@tu-proyecto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END RSA PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-de-al-menos-32-caracteres-generado-con-openssl"
NEXTAUTH_URL="http://localhost:3000"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Ptime"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Credenciales Admin (solo para setup inicial) ─────────────────────────────
# En producción usar un proveedor de auth real (Google OAuth, etc.)
ADMIN_EMAIL="admin@tuempresa.com"
ADMIN_PASSWORD_HASH="bcrypt_hash_aqui"
